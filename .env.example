# App
APP_NAME=OpenClaw
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://openclaw:password@postgres:5432/openclaw

# Redis
REDIS_URL=redis://redis:6379/0

# WhatsApp (Meta Cloud API)
WA_VERIFY_TOKEN=your-verify-token
WA_ACCESS_TOKEN=your-access-token
WA_PHONE_NUMBER_ID=your-phone-number-id
WA_APP_SECRET=your-app-secret
OWNER_PHONE=your-whatsapp-number

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-key
CLAUDE_MODEL=claude-sonnet-4-20250514

# Google AI (Nano Banana + Veo)
GOOGLE_AI_API_KEY=your-google-ai-key

# Firecrawl
FIRECRAWL_API_KEY=your-firecrawl-key

# Gmail
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_SENDER_EMAIL=your@gmail.com

# Vercel
VERCEL_TOKEN=your-vercel-token
VERCEL_TEAM_ID=
DEPLOY_DOMAIN=openclaw.site

# Storage
STORAGE_PATH=/data/projects

# Postgres
POSTGRES_PASSWORD=changeme

# Research Agent
RESEARCH_INTERVAL_HOURS=6
RESEARCH_SOURCES=awwwards,dribbble,css_tricks,smashing_magazine,codrops

# Learning Agent
LEARNING_DAILY_CRON=03:00
RELEVANCE_DECAY_HALFLIFE_DAYS=90

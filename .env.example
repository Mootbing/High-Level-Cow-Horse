# Database (password must match POSTGRES_PASSWORD below)
DATABASE_URL=postgresql+asyncpg://openclaw:changeme@localhost:5432/openclaw

# Anthropic (OpenClaw uses this via provider config)
ANTHROPIC_API_KEY=your-anthropic-key

# Google AI (Nano Banana + Veo 3)
GOOGLE_AI_API_KEY=your-google-ai-key

# Google Places API (New) — for competitor discovery
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Gmail
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_SENDER_EMAIL=your@gmail.com

# GitHub (bot account PAT with 'repo' scope)
GITHUB_PAT=ghp_your-github-pat

# Vercel
VERCEL_TOKEN=your-vercel-token
VERCEL_TEAM_ID=
DEPLOY_DOMAIN=openclaw.site

# Storage
STORAGE_PATH=./data/projects

# Lead Generation / Prospecting
PROSPECTING_ENABLED=false
PROSPECTING_INDUSTRIES=restaurant,salon,dentist
PROSPECTING_LOCATIONS=Austin TX,Dallas TX
PROSPECTING_DAILY_LIMIT=50

# Postgres
POSTGRES_PASSWORD=changeme

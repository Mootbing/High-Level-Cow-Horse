# =============================================================================
# OpenClaw — EC2 Environment Variables
#
# Copy to your project root:
#   cp deploy/ec2/.env.example .env
#
# NOTE: No ANTHROPIC_API_KEY required! Run `openclaw login` to authenticate
# with Claude via OAuth. The API key is only a fallback.
# =============================================================================

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
APP_NAME=Clarmi Design Studio
DEBUG=false
LOG_LEVEL=INFO

# Database (containers use service name "postgres" as host)
DATABASE_URL=postgresql+asyncpg://openclaw:${POSTGRES_PASSWORD}@postgres:5432/openclaw
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Redis (containers use service name "redis" as host)
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Auth — Claude credentials
# ---------------------------------------------------------------------------
# Primary: Run `openclaw login` on the host. Credentials are stored at
# ~/.openclaw/credentials.json and mounted into containers read-only.
# The path below is where the container looks for the mounted credentials.
OPENCLAW_CREDENTIALS_PATH=/home/openclaw/.openclaw/credentials.json

# Fallback only — not needed if you use `openclaw login`
# ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Claude
# ---------------------------------------------------------------------------
CLAUDE_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# Google AI (Imagen + Veo — image/video generation)
# ---------------------------------------------------------------------------
GOOGLE_AI_API_KEY=your-google-ai-api-key

# ---------------------------------------------------------------------------
# Firecrawl (web scraping for research skill)
# ---------------------------------------------------------------------------
FIRECRAWL_API_KEY=your-firecrawl-api-key

# ---------------------------------------------------------------------------
# Gmail (outbound skill sends emails)
# ---------------------------------------------------------------------------
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_SENDER_EMAIL=your@gmail.com

# ---------------------------------------------------------------------------
# GitHub (engineer skill creates repos for generated websites)
# ---------------------------------------------------------------------------
GITHUB_PAT=ghp_your-github-pat

# ---------------------------------------------------------------------------
# Vercel (engineer skill deploys sites)
# ---------------------------------------------------------------------------
VERCEL_TOKEN=your-vercel-token
VERCEL_TEAM_ID=
DEPLOY_DOMAIN=openclaw.site

# ---------------------------------------------------------------------------
# WhatsApp (Meta Cloud API — inbound/outbound messaging)
# ---------------------------------------------------------------------------
WA_VERIFY_TOKEN=pick-a-random-verify-token
WA_ACCESS_TOKEN=your-whatsapp-access-token
WA_PHONE_NUMBER_ID=your-phone-number-id
WA_APP_SECRET=your-whatsapp-app-secret
OWNER_PHONE=your-whatsapp-number-with-country-code

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
STORAGE_PATH=/data/projects

# ---------------------------------------------------------------------------
# EC2 Instance
# ---------------------------------------------------------------------------
EC2_PUBLIC_IP=your-ec2-public-ip
MAX_PARALLEL_PROJECTS=5

# ---------------------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------------------
DASHBOARD_SECRET=CHANGE_ME_TO_A_STRONG_SECRET
JWT_SECRET=CHANGE_ME_TO_ANOTHER_STRONG_SECRET
JWT_EXPIRY_HOURS=24

# ---------------------------------------------------------------------------
# Skills
# ---------------------------------------------------------------------------
# Optional: override the skills directory (defaults to ./skills in the repo)
# SKILLS_DIR=./skills

# ---------------------------------------------------------------------------
# Timeouts
# ---------------------------------------------------------------------------
TASK_TIMEOUT_S=600
HEAVY_TASK_TIMEOUT_S=1800

# ---------------------------------------------------------------------------
# Research skill
# ---------------------------------------------------------------------------
RESEARCH_INTERVAL_HOURS=6
RESEARCH_SOURCES=awwwards,dribbble,css_tricks,smashing_magazine,codrops

# ---------------------------------------------------------------------------
# Learning skill
# ---------------------------------------------------------------------------
LEARNING_DAILY_CRON=03:00
RELEVANCE_DECAY_HALFLIFE_DAYS=90
